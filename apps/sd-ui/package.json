{
  "name": "simpl-sd-ui",
  "type": "module",
  "version": "1.12.1",
  "scripts": {
    "dev": "dotenvx run -- astro dev --host 0.0.0.0",
    "start": "dotenvx run -- astro dev",
    "build": "astro check && dotenvx run -- astro build",
    "preview": "dotenvx run -- astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ci": "vitest run --reporter=junit --outputFile=./junit.xml --coverage",
    "cleanup": "rimraf ./dist ./coverage junit.xml",
    "start:build": "NODE_ENV=production dotenvx run -- node ./dist/server/entry.mjs"
  },
